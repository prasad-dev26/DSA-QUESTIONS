#include<bits/stdc++.h>
using namespace std;

void reverseArr(vector<int> &a, int i, int j) {
    while(i < j) {
        swap(a[i], a[j]);
        i++;
        j--;
    }
}

int main() {
    int n;
    cin >> n;

    vector<int> a(n);
    for(int i = 0; i < n; i++) {
        cin >> a[i];
    }

    int k;
    cin >> k;

    k = k % n;  // important 💀

    // Step 1: reverse last k elements
    reverseArr(a, n-k, n-1);

    // Step 2: reverse first n-k elements
    reverseArr(a, 0, n-k-1);

    // Step 3: reverse whole array
    reverseArr(a, 0, n-1);

    // print
    for(int x : a) {
        cout << x << " ";
    }
}
